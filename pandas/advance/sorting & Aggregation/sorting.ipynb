   "source": [
    "# sorting data in 1 column\n",
    "import pandas as pd\n",
    "data = {\n",
    "    'Name' : [\"Rahul\", \"Debu\", \"Dev\", \"Subho\"],\n",
    "    'Age' : [22,21,15,65],\n",
    "    \"Salary\" : [2000,800,1000,6500]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "df.sort_values(by= \"Age\", ascending=True, inplace= True)\n",
    "print(df)"
   ]
  }
