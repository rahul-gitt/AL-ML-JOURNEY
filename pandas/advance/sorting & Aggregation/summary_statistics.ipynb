    "# summary statistics\n",
    "import pandas as pd\n",
    "data = {\n",
    "    'Name' : [\"Rahul\", 'Dev', \"Debu\"],\n",
    "    'Age' : [19,22,20],\n",
    "    'Salary' : [10000,20000,30000]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "avg_salary = df['Salary'].mean()\n",
    "print(avg_salary)"
   ]
  }
