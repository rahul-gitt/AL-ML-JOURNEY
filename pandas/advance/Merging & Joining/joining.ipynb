   "source": [
    "# Inner join\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "students = pd.DataFrame({\n",
    "    'ID' : [100,101,103],\n",
    "    'Name': ['Rahul', 'Dev','Debu']\n",
    "})\n",
    "\n",
    "marks = pd.DataFrame({\n",
    "    'ID': [100,101,103],\n",
    "    'Marks': [90,80,86]\n",
    "})\n",
    "\n",
    "result = pd.merge(students,marks,on=\"ID\",how= \"inner\")\n",
    "print(result)"
   ]
  }
 ],
