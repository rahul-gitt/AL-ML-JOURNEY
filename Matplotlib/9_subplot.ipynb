    "import matplotlib.pyplot as plt\n",
    "\n",
    "x = [1,2,3,4]\n",
    "y = [10,20,15,25]\n",
    " \n",
    "plt.subplot(1,2,1)\n",
    "plt.plot(x,y)\n",
    "plt.title(\"Line chart\")\n",
    "\n",
    "plt.subplot(1,2,2)\n",
    "plt.bar(x,y)\n",
    "plt.title(\"Bar chart\")\n",
    "plt.show()"
   ]
  }
