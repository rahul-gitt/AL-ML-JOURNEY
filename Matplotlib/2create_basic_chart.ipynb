    "import matplotlib.pyplot as plt\n",
    "\n",
    "x = [\"Sun\", \"Mon\", \"Tues\", \"Wed\", \"Thus\", \"Fri\"]\n",
    "y = [15,8,13,5,20,9]\n",
    "\n",
    "plt.plot(x,y)\n",
    "\n",
    "plt.title(\"Sales this week \")\n",
    "\n",
    "plt.xlabel('Day of the week')\n",
    "plt.ylabel('Sales per  Day')   \n",
    "\n",
    "plt.show()"
   ]
  }
