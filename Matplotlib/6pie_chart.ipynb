   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "regions= ['North', 'South', 'East', 'West']\n",
    "sales= [20000, 7000, 26900, 9580]\n",
    "\n",
    "plt.pie(sales, labels = regions, colors= ['gold', 'skyblue', 'lightgreen', 'coral'], autopct= '%1.1f%%')\n",
    "plt.title(\"Region wise sales\")\n",
    "plt.show()"
   ]
  }
