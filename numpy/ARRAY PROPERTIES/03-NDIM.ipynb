    "# NDIM (Number of dimentions)\n",
    "# It  tell us the number of dimentions\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "arr_1d = np.array([1,2,3])\n",
    "arr_2d = np.array([[10,20,30], [40,50,6]])\n",
    "arr_3d = np.array([[[1,2],[3,4],[5,6]]])\n",
    "\n",
    "print(arr_1d.ndim)\n",
    "print(arr_2d.ndim)\n",
    "print(arr_3d.ndim)\n"
   ]
  }
