    "#How to access a specific element in an array\n",
    "\n",
    "import numpy as np \n",
    "arr = np.array([10,20,30,40,50])\n",
    "\n",
    "print(arr[0])   #first elemnt\n",
    "print(arr[2])   #3rd element\n",
    "print(arr[-1])   #Reverse indexing last element"
   ]
  }
