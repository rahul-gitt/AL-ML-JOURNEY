    "import numpy as np\n",
    "arr = np.array([10,20,30,40,50,60])\n",
    "\n",
    "print(arr[1:5]) # index 1 to 4\n",
    "print(arr[:4]) # index 0 to 3\n",
    "print(arr[::2]) # every 2nd element\n",
    "print(arr[::-1])  # reverse the array"
   ]
